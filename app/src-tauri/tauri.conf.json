{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TNM Downloader",
  "version": "0.5.0",
  "identifier": "com.tnm.downloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TNM Downloader",
        "width": 1400,
        "height": 880,
        "minWidth": 1120,
        "minHeight": 700,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["magnet"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCNzZBN0I3NjBEMTY1QkEKUldTNlpkRmd0NmQyYTlZd2pNRCt0bXlML2d4NEtaaTh5VzV1am50d1BGcHA3eUZIKy9VVSszbHUK",
      "endpoints": [
        "https://github.com/gant123/tnm-downloader/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "ext": ["torrent"],
        "name": "BitTorrent file",
        "description": "BitTorrent metadata file",
        "mimeType": "application/x-bittorrent"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
